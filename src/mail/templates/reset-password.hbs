<table style="background-color: #ffffff; max-width: 600px; margin: auto; border: none;">
  <!-- Header Section -->
  <tr>
    <td style="padding: 20px 0;text-align: center;">
      <h1 style="font-family: Arial, sans-serif;font-size: 24px; margin: 0;">Reset Your Password</h1>
    </td>
  </tr>
  <!-- /Header Section -->

  <!-- Content Section -->
  <tr>
    <td style="padding: 20px; font-family: Arial, sans-serif;font-size: 16px; line-height: 1.5; text-align: center;">
      Hi {{name}}, we received a request to reset your Lynx account password.
    </td>
  </tr>
  <!-- /Content Section -->

  <!-- Button Section -->
  <tr>
    <td style="padding: 10px;text-align: center;">
      <p style="font-family: Arial, sans-serif;font-size: 16px;">Click the link below to set a new password:</p>
    </td>
  </tr>
  <tr>
    <td style="padding: 10px;text-align: center;">
      <a href="{{resetLink}}" style="font-family: Arial, sans-serif;">Reset Password</a>
    </td>
  </tr>
  <!-- /Button Section -->

  <!-- Footer Section -->
  <tr>
    <td style="padding: 20px; font-family: Arial, sans-serif;font-size: 14px; line-height: 1.5; text-align: center; color: #888;">
      If you didn't request this, you can safely ignore this email. This link will expire shortly.
    </td>
  </tr>
  <!-- /Footer Section -->
</table>
